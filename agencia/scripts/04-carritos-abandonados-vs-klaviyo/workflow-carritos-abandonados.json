      "main": [[{ "node": "¿Completó la compra (24h)?", "type": "main", "index": 0 }]]
    },
    "¿Completó la compra (24h)?": {
      "main": [
        [{ "node": "Fin — Ya compró ✓", "type": "main", "index": 0 }],
