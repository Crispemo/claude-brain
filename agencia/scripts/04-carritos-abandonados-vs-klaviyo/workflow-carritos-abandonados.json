  },
  "settings": {
    "executionOrder": "v1"
  },
  "active": false,
  "meta": {
    "description": "Recupera carritos abandonados de Shopify con email personalizado por IA + WhatsApp. Secuencia: 30 min + 24h. Para si el cliente compra en cualquier momento.",
    "credentials_needed": [
      "SHOPIFY_STORE — nombre de tu tienda (sin .myshopify.com)",
      "SHOPIFY_ACCESS_TOKEN — Admin API token de Shopify",
      "TWILIO_ACCOUNT_SID — de tu cuenta Twilio",
      "TWILIO_WHATSAPP_NUMBER — número Twilio con WhatsApp activado",
      "FROM_EMAIL — tu email de envío",
      "OpenAI API key"
    ]
  }
