{
  "name": "Shopify — Generar Fichas de Producto con IA (bulk desde Google Sheets)",
  "nodes": [
    {
      "id": "manual-trigger",
      "name": "Iniciar generación",
      "type": "n8n-nodes-base.manualTrigger",
      "position": [240, 300],
      "parameters": {}
    },
    {
      "id": "read-sheet",
      "name": "Leer catálogo de Google Sheets",
      "type": "n8n-nodes-base.googleSheets",
      "position": [460, 300],
      "parameters": {
        "operation": "read",
        "documentId": "={{$env.GOOGLE_SHEET_ID}}",
        "sheetName": "Catálogo",
        "range": "A:H",
        "options": {
          "headerRow": true
        }
      },
      "credentials": {
        "googleSheetsOAuth2Api": { "id": "google-sheets-creds", "name": "Google Sheets" }
      }
    },
    {
      "id": "filter-pending",
      "name": "Solo productos sin ficha generada",
      "type": "n8n-nodes-base.filter",
      "position": [680, 300],
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{$json.Generado}}",
              "operation": "isEmpty"
            }
          ]
        }
      }
    },
    {
      "id": "split-batches",
      "name": "Procesar de 1 en 1",
      "type": "n8n-nodes-base.splitInBatches",
      "position": [900, 300],
      "parameters": {
        "batchSize": 1,
        "options": {}
      }
    },
    {
      "id": "generate-ficha",
      "name": "Generar ficha con IA (Claude/GPT)",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "position": [1120, 300],
      "parameters": {
        "resource": "text",
        "operation": "message",
        "modelId": "gpt-4o",
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "Eres un experto en copywriting para ecommerce. Escribes fichas de producto que convierten. Siempre respondes en JSON válido, sin texto extra, solo el JSON."
            },
            {
              "role": "user",
              "content": "=Genera la ficha completa para este producto.\n\nNombre: {{$json['Nombre']}}\nCategoría: {{$json['Categoría']}}\nCaracterísticas técnicas: {{$json['Características']}}\nPúblico objetivo: {{$json['Público']}}\nPrecio: {{$json['Precio']}}€\nDiferenciador clave: {{$json['Diferenciador']}}\nIdioma: Español\n\nDevuelve SOLO este JSON:\n{\n  \"titulo\": \"título SEO máximo 70 caracteres, incluir keyword principal y marca si aplica\",\n  \"meta_description\": \"meta description 150-155 caracteres con beneficio principal y CTA suave\",\n  \"descripcion_html\": \"<p>150-200 palabras en HTML. Empieza con el beneficio principal (no el nombre del producto). Segundo párrafo: características clave. Tercero: para quién es ideal. Tono: cercano, sin tecnicismos, vende la transformación no las especificaciones.</p>\",\n  \"bullets\": [\n    \"Beneficio 1 — no característica, beneficio que obtiene el usuario\",\n    \"Beneficio 2\",\n    \"Beneficio 3\",\n    \"Beneficio 4\",\n    \"Beneficio 5\"\n  ],\n  \"tags\": [\"tag1\", \"tag2\", \"tag3\", \"tag4\", \"tag5\", \"tag6\"]\n}"
            }
          ]
        }
      },
      "credentials": {
        "openAiApi": { "id": "openai-creds", "name": "OpenAI" }
      }
    },
    {
      "id": "parse-json",
      "name": "Parsear respuesta JSON",
      "type": "n8n-nodes-base.code",
      "position": [1340, 300],
      "parameters": {
        "jsCode": "const raw = $input.first().json.message.content;\nconst match = raw.match(/\\{[\\s\\S]*\\}/);\nif (!match) throw new Error('No se pudo parsear el JSON de la ficha');\nconst ficha = JSON.parse(match[0]);\nconst producto_id = $node['Procesar de 1 en 1'].json['ID Shopify'];\nconst row_number = $node['Procesar de 1 en 1'].json['_rowNumber'];\nreturn [{ json: { ...ficha, producto_id, row_number } }];"
      }
    },
    {
      "id": "update-shopify",
      "name": "Actualizar producto en Shopify",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1560, 200],
      "parameters": {
        "method": "PUT",
        "url": "=https://{{$env.SHOPIFY_STORE}}.myshopify.com/admin/api/2024-01/products/{{$json.producto_id}}.json",
        "headers": {
          "parameters": [
            { "name": "X-Shopify-Access-Token", "value": "={{$env.SHOPIFY_ACCESS_TOKEN}}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "product",
              "value": "={{JSON.stringify({ title: $json.titulo, body_html: $json.descripcion_html + '<ul>' + $json.bullets.map(b => '<li>' + b + '</li>').join('') + '</ul>', tags: $json.tags.join(',') })}}"
            }
          ]
        }
      }
    },
    {
      "id": "mark-done",
      "name": "Marcar como generado en Sheets",
      "type": "n8n-nodes-base.googleSheets",
      "position": [1560, 420],
      "parameters": {
        "operation": "update",
        "documentId": "={{$env.GOOGLE_SHEET_ID}}",
        "sheetName": "Catálogo",
        "options": {
          "headerRow": true
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "Generado": "={{new Date().toLocaleString('es-ES')}}",
            "Título generado": "={{$node['Parsear respuesta JSON'].json.titulo}}",
            "JSON completo": "={{JSON.stringify($node['Parsear respuesta JSON'].json)}}"
          }
        },
        "where": {
          "values": [
            {
              "column": "_rowNumber",
              "value": "={{$node['Parsear respuesta JSON'].json.row_number}}"
            }
          ]
        }
      },
      "credentials": {
        "googleSheetsOAuth2Api": { "id": "google-sheets-creds", "name": "Google Sheets" }
      }
    },
    {
      "id": "wait-between",
      "name": "Esperar 2 segundos (rate limit)",
      "type": "n8n-nodes-base.wait",
      "position": [1780, 300],
      "parameters": {
        "amount": 2,
        "unit": "seconds"
      }
    }
  ],
  "connections": {
    "Iniciar generación": {
      "main": [[{ "node": "Leer catálogo de Google Sheets", "type": "main", "index": 0 }]]
    },
    "Leer catálogo de Google Sheets": {
      "main": [[{ "node": "Solo productos sin ficha generada", "type": "main", "index": 0 }]]
    },
    "Solo productos sin ficha generada": {
      "main": [[{ "node": "Procesar de 1 en 1", "type": "main", "index": 0 }]]
    },
    "Procesar de 1 en 1": {
      "main": [[{ "node": "Generar ficha con IA (Claude/GPT)", "type": "main", "index": 0 }]]
    },
    "Generar ficha con IA (Claude/GPT)": {
      "main": [[{ "node": "Parsear respuesta JSON", "type": "main", "index": 0 }]]
    },
    "Parsear respuesta JSON": {
      "main": [[
        { "node": "Actualizar producto en Shopify", "type": "main", "index": 0 },
        { "node": "Marcar como generado en Sheets", "type": "main", "index": 0 }
      ]]
    },
    "Actualizar producto en Shopify": {
      "main": [[{ "node": "Esperar 2 segundos (rate limit)", "type": "main", "index": 0 }]]
    },
    "Esperar 2 segundos (rate limit)": {
      "main": [[{ "node": "Procesar de 1 en 1", "type": "main", "index": 0 }]]
    }
  },
  "settings": { "executionOrder": "v1" },
  "active": false,
  "meta": {
    "description": "Lee productos de Google Sheets, genera fichas completas (título SEO, meta description, descripción HTML, bullets, tags) con IA, y actualiza Shopify automáticamente.",
    "google_sheet_columns": "ID Shopify | Nombre | Categoría | Características | Público | Precio | Diferenciador | Generado (automático)",
    "credentials_needed": [
      "GOOGLE_SHEET_ID — ID del Google Sheet con el catálogo",
      "Google Sheets OAuth2 credentials",
      "SHOPIFY_STORE + SHOPIFY_ACCESS_TOKEN",
      "OpenAI API key"
    ]
  }
}
